<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Panel — BLSP</title>
    <link rel="icon" href="/img/logo.png" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
        :root {
            --sidebar-w: 260px;
            --sidebar-bg: #1a2332;
            --sidebar-hover: #263449;
            --sidebar-active: #2563eb;
            --header-h: 60px;
        }
        *, *::before, *::after { box-sizing: border-box; }
        body { background: #f1f5f9; font-family: 'Segoe UI', sans-serif; margin: 0; }

        /* ── Sidebar ── */
        .sidebar {
            position: fixed; top: 0; left: 0; height: 100vh;
            width: var(--sidebar-w); background: var(--sidebar-bg);
            overflow-y: auto; z-index: 1040;
            display: flex; flex-direction: column;
            transition: transform .25s ease;
        }
        .sidebar-brand {
            padding: 22px 20px 18px;
            border-bottom: 1px solid rgba(255,255,255,.08);
            flex-shrink: 0;
        }
        .sidebar-brand h5 { color: #fff; font-weight: 700; margin: 0; font-size: .95rem; }
        .sidebar-brand p  { color: rgba(255,255,255,.45); font-size: .72rem; margin: 2px 0 0; }
        .sidebar-nav { padding: 10px 0; flex: 1; }
        .nav-label {
            color: rgba(255,255,255,.3); font-size: .65rem; font-weight: 700;
            letter-spacing: .1em; text-transform: uppercase;
            padding: 16px 20px 6px;
        }
        .s-link {
            display: flex; align-items: center; gap: 10px;
            padding: 9px 20px; color: rgba(255,255,255,.65);
            text-decoration: none; font-size: .84rem; cursor: pointer;
            border: none; background: none; width: 100%; text-align: left;
            transition: background .15s, color .15s;
        }
        .s-link:hover  { background: var(--sidebar-hover); color: #fff; }
        .s-link.active { background: var(--sidebar-active); color: #fff; }
        .s-link i { width: 18px; font-size: .95rem; flex-shrink: 0; }
        .s-link .badge { margin-left: auto; font-size: .65rem; }
        .sidebar-footer {
            border-top: 1px solid rgba(255,255,255,.08);
            padding: 12px 0; flex-shrink: 0;
        }

        /* ── Main ── */
        .main { margin-left: var(--sidebar-w); min-height: 100vh; }
        .topbar {
            background: #fff; height: var(--header-h);
            display: flex; align-items: center; justify-content: space-between;
            padding: 0 24px; border-bottom: 1px solid #e2e8f0;
            position: sticky; top: 0; z-index: 100;
        }
        .topbar-title { font-weight: 700; color: #1e293b; font-size: .95rem; margin: 0; }
        .content { padding: 24px; }

        /* ── Sections ── */
        .admin-section { display: none; }
        .admin-section.active { display: block; }

        /* ── Cards ── */
        .stat-card {
            background: #fff; border-radius: 12px;
            padding: 20px; border: 1px solid #e2e8f0;
        }
        .stat-icon {
            width: 46px; height: 46px; border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.2rem; flex-shrink: 0;
        }
        .form-card {
            background: #fff; border-radius: 12px;
            padding: 24px; border: 1px solid #e2e8f0; margin-bottom: 20px;
        }
        .form-card h5 { font-weight: 700; color: #1e293b; margin-bottom: 16px; font-size: .95rem; }
        .table-card {
            background: #fff; border-radius: 12px;
            border: 1px solid #e2e8f0; overflow: hidden;
        }
        .table-card .table { margin: 0; }
        .table-card .table thead th {
            background: #f8fafc; font-size: .75rem; font-weight: 600;
            text-transform: uppercase; letter-spacing: .05em;
            color: #64748b; border-bottom: 1px solid #e2e8f0; white-space: nowrap;
        }
        .table-card .table td { vertical-align: middle; font-size: .87rem; }
        .section-hdr {
            display: flex; align-items: center; justify-content: space-between;
            margin-bottom: 20px;
        }
        .section-hdr h4 { font-weight: 700; color: #1e293b; margin: 0; font-size: 1.15rem; }

        /* ── Mobile ── */
        .menu-toggle { display: none; }
        @media (max-width: 768px) {
            .sidebar { transform: translateX(-100%); }
            .sidebar.open { transform: translateX(0); }
            .main { margin-left: 0; }
            .menu-toggle { display: inline-flex; }
            .overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.4); z-index: 1039; }
            .overlay.show { display: block; }
        }
    </style>
</head>
<body>

<!-- Mobile overlay -->
<div class="overlay" id="overlay" onclick="closeSidebar()"></div>

<!-- ── Sidebar ─────────────────────────────────────────────── -->
<aside class="sidebar" id="sidebar">
    <div class="sidebar-brand">
        <h5><img src="/img/logo.png" alt="BLSP" style="height:22px;width:auto;object-fit:contain;margin-right:8px;vertical-align:middle;">BLSP Admin</h5>
        <p>Building Lives Sustainable Project</p>
    </div>

    <nav class="sidebar-nav">
        <div class="nav-label">Overview</div>
        <button class="s-link active" data-section="dashboard" onclick="showSection('dashboard',this)">
            <i class="bi bi-grid-1x2-fill"></i> Dashboard
        </button>

        <div class="nav-label">Content</div>
        <button class="s-link" data-section="annual-reports" onclick="showSection('annual-reports',this)">
            <i class="bi bi-file-earmark-bar-graph-fill"></i> Annual Reports
            <span class="badge bg-secondary"><%= annualReports.length %></span>
        </button>
        <button class="s-link" data-section="team" onclick="showSection('team',this)">
            <i class="bi bi-people-fill"></i> Team Members
            <span class="badge bg-secondary"><%= teamMembers.length %></span>
        </button>
        <button class="s-link" data-section="publications" onclick="showSection('publications',this)">
            <i class="bi bi-journal-richtext"></i> Publications
            <span class="badge bg-secondary"><%= publications.length %></span>
        </button>
        <button class="s-link" data-section="partners" onclick="showSection('partners',this)">
            <i class="bi bi-handshake-fill"></i> Partners
            <span class="badge bg-secondary"><%= partners.length %></span>
        </button>

        <div class="nav-label">Careers</div>
        <button class="s-link" data-section="jobs" onclick="showSection('jobs',this)">
            <i class="bi bi-briefcase-fill"></i> Jobs
            <span class="badge bg-secondary"><%= jobs.length %></span>
        </button>
        <button class="s-link" data-section="applications" onclick="showSection('applications',this)">
            <i class="bi bi-person-lines-fill"></i> Job Applications
            <span class="badge bg-warning text-dark"><%= applications.length %></span>
        </button>

        <div class="nav-label">Community</div>
        <button class="s-link" data-section="memberships" onclick="showSection('memberships',this)">
            <i class="bi bi-person-badge-fill"></i> Memberships
            <span class="badge bg-warning text-dark"><%= membershipRequests.length %></span>
        </button>
        <button class="s-link" data-section="newsletter" onclick="showSection('newsletter',this)">
            <i class="bi bi-envelope-fill"></i> Newsletter
            <span class="badge bg-secondary"><%= newsletterSubscribers.length %></span>
        </button>
        <button class="s-link" data-section="contacts" onclick="showSection('contacts',this)">
            <i class="bi bi-chat-dots-fill"></i> Contact Inquiries
            <span class="badge bg-warning text-dark"><%= contacts.length %></span>
        </button>
    </nav>

    <div class="sidebar-footer">
        <form action="/admin/logout" method="POST" class="m-0">
            <button type="submit" class="s-link" style="color:#f87171;">
                <i class="bi bi-box-arrow-left"></i> Logout
            </button>
        </form>
    </div>
</aside>

<!-- ── Main ──────────────────────────────────────────────────── -->
<div class="main">
    <!-- Topbar -->
    <div class="topbar">
        <div class="d-flex align-items-center gap-3">
            <button class="btn btn-sm btn-light menu-toggle" onclick="openSidebar()">
                <i class="bi bi-list fs-5"></i>
            </button>
            <h6 class="topbar-title" id="topbarTitle">Dashboard</h6>
        </div>
        <span class="text-muted small d-none d-sm-inline">BLSP Admin Panel</span>
    </div>

    <div class="content">

        <!-- ════════════════ DASHBOARD ════════════════ -->
        <div class="admin-section active" id="dashboard">
            <div class="section-hdr"><h4>Dashboard</h4></div>
            <div class="row g-3">
                <div class="col-6 col-xl-3">
                    <div class="stat-card">
                        <div class="d-flex align-items-center gap-3">
                            <div class="stat-icon bg-primary bg-opacity-10 text-primary"><i class="bi bi-people-fill"></i></div>
                            <div><div class="fs-3 fw-bold lh-1"><%= teamMembers.length %></div><div class="text-muted small mt-1">Team Members</div></div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-xl-3">
                    <div class="stat-card">
                        <div class="d-flex align-items-center gap-3">
                            <div class="stat-icon bg-success bg-opacity-10 text-success"><i class="bi bi-briefcase-fill"></i></div>
                            <div><div class="fs-3 fw-bold lh-1"><%= jobs.length %></div><div class="text-muted small mt-1">Open Jobs</div></div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-xl-3">
                    <div class="stat-card">
                        <div class="d-flex align-items-center gap-3">
                            <div class="stat-icon bg-warning bg-opacity-10 text-warning"><i class="bi bi-envelope-fill"></i></div>
                            <div><div class="fs-3 fw-bold lh-1"><%= newsletterSubscribers.length %></div><div class="text-muted small mt-1">Subscribers</div></div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-xl-3">
                    <div class="stat-card">
                        <div class="d-flex align-items-center gap-3">
                            <div class="stat-icon bg-info bg-opacity-10 text-info"><i class="bi bi-chat-dots-fill"></i></div>
                            <div><div class="fs-3 fw-bold lh-1"><%= contacts.length %></div><div class="text-muted small mt-1">Inquiries</div></div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-xl-3">
                    <div class="stat-card">
                        <div class="d-flex align-items-center gap-3">
                            <div class="stat-icon bg-danger bg-opacity-10 text-danger"><i class="bi bi-person-lines-fill"></i></div>
                            <div><div class="fs-3 fw-bold lh-1"><%= applications.length %></div><div class="text-muted small mt-1">Job Applications</div></div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-xl-3">
                    <div class="stat-card">
                        <div class="d-flex align-items-center gap-3">
                            <div class="stat-icon bg-secondary bg-opacity-10 text-secondary"><i class="bi bi-person-badge-fill"></i></div>
                            <div><div class="fs-3 fw-bold lh-1"><%= membershipRequests.length %></div><div class="text-muted small mt-1">Memberships</div></div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-xl-3">
                    <div class="stat-card">
                        <div class="d-flex align-items-center gap-3">
                            <div class="stat-icon bg-success bg-opacity-10 text-success"><i class="bi bi-handshake-fill"></i></div>
                            <div><div class="fs-3 fw-bold lh-1"><%= partners.length %></div><div class="text-muted small mt-1">Partners</div></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ════════════════ ANNUAL REPORTS ════════════════ -->
        <div class="admin-section" id="annual-reports">
            <div class="section-hdr"><h4>Annual Reports</h4></div>

            <div class="form-card">
                <h5><i class="bi bi-cloud-upload me-2 text-primary"></i>Upload New Report</h5>
                <form action="/admin/annual-reports" method="POST" enctype="multipart/form-data">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Report Title <span class="text-danger">*</span></label>
                            <input class="form-control" name="reportTitle" placeholder="e.g. Annual Report 2024" required />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Year <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" name="reportYear" placeholder="2024" required />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Report File (PDF) <span class="text-danger">*</span></label>
                            <input type="file" class="form-control" name="reportFile" accept=".pdf,.doc,.docx" required />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Short Description</label>
                            <textarea class="form-control" name="description" rows="2" placeholder="Brief summary…"></textarea>
                        </div>
                        <div class="col-12">
                            <button class="btn btn-primary px-4"><i class="bi bi-upload me-2"></i>Upload Report</button>
                        </div>
                    </div>
                </form>
            </div>

            <div class="table-card">
                <div class="p-3 border-bottom d-flex align-items-center justify-content-between">
                    <span class="fw-600 text-secondary small text-uppercase">Existing Reports (<%= annualReports.length %>)</span>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead><tr><th>Title</th><th>Year</th><th>Description</th><th>File</th><th>Submitted</th><th>Actions</th></tr></thead>
                        <tbody>
                        <% annualReports.forEach(r => { %>
                            <tr>
                                <td class="fw-semibold"><%= r.reportTitle %></td>
                                <td><span class="badge bg-light text-dark border"><%= r.reportYear %></span></td>
                                <td><small class="text-muted"><%= (r.description || '—').substring(0,60) %><%= (r.description || '').length > 60 ? '…' : '' %></small></td>
                                <td>
                                    <% if (r.reportUrl) { %>
                                        <a href="/uploads<%= r.reportUrl %>" target="_blank" class="btn btn-outline-info btn-sm">
                                            <i class="bi bi-file-earmark-pdf"></i> View
                                        </a>
                                    <% } else { %>
                                        <span class="text-muted small">No file</span>
                                    <% } %>
                                </td>
                                <td><small><%= new Date(r.submittedAt).toLocaleDateString() %></small></td>
                                <td>
                                    <button class="btn btn-warning btn-sm me-1"
                                        onclick="editReport('<%= r.id %>','<%- r.reportTitle.replace(/'/g, "\\'") %>','<%= r.reportYear %>','<%- (r.description || '').replace(/'/g, "\\'").replace(/\n/g, ' ') %>')">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <form action="/admin/annual-reports/delete/<%= r.id %>" method="POST" class="d-inline"
                                        onsubmit="return confirm('Delete this report?')">
                                        <button type="submit" class="btn btn-danger btn-sm"><i class="bi bi-trash"></i></button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                        <% if (!annualReports.length) { %><tr><td colspan="6" class="text-center text-muted py-4">No reports yet.</td></tr><% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- ════════════════ TEAM ════════════════ -->
        <div class="admin-section" id="team">
            <div class="section-hdr"><h4>Team Members</h4></div>

            <div class="form-card">
                <h5><i class="bi bi-person-plus me-2 text-primary"></i>Add Team Member</h5>
                <form action="/admin/team" method="POST" enctype="multipart/form-data">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Full Name <span class="text-danger">*</span></label>
                            <input class="form-control" name="fullName" placeholder="Full Name" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Role <span class="text-danger">*</span></label>
                            <input class="form-control" name="role" placeholder="e.g. Programme Manager" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Profile Photo <span class="text-danger">*</span></label>
                            <input type="file" class="form-control" name="image" accept="image/*" required />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Bio / Description</label>
                            <textarea class="form-control" name="description" rows="2" placeholder="Short bio…"></textarea>
                        </div>
                        <div class="col-12">
                            <button class="btn btn-primary px-4"><i class="bi bi-plus-circle me-2"></i>Add Member</button>
                        </div>
                    </div>
                </form>
            </div>

            <div class="table-card">
                <div class="p-3 border-bottom">
                    <span class="fw-600 text-secondary small text-uppercase">Team (<%= teamMembers.length %>)</span>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead><tr><th>Photo</th><th>Name</th><th>Role</th><th>Bio</th><th>Actions</th></tr></thead>
                        <tbody>
                        <% teamMembers.forEach(m => { %>
                            <tr>
                                <td><img src="<%= m.imageUrl %>" alt="" style="width:40px;height:40px;object-fit:cover;border-radius:8px;" /></td>
                                <td class="fw-semibold"><%= m.fullName %></td>
                                <td><small><%= m.role %></small></td>
                                <td><small class="text-muted"><%= (m.description || '—').substring(0,50) %><%= (m.description || '').length > 50 ? '…' : '' %></small></td>
                                <td>
                                    <button class="btn btn-warning btn-sm me-1" data-id="<%= m.id %>"
                                        data-name="<%= m.fullName %>" data-role="<%= m.role %>"
                                        data-description="<%- (m.description || '') %>" onclick="editMember(this)">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <form action="/admin/team/delete/<%= m.id %>" method="POST" class="d-inline"
                                        onsubmit="return confirm('Delete this team member?')">
                                        <button type="submit" class="btn btn-danger btn-sm"><i class="bi bi-trash"></i></button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                        <% if (!teamMembers.length) { %><tr><td colspan="5" class="text-center text-muted py-4">No team members yet.</td></tr><% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- ════════════════ PUBLICATIONS ════════════════ -->
        <div class="admin-section" id="publications">
            <div class="section-hdr"><h4>Publications</h4></div>

            <div class="form-card">
                <h5><i class="bi bi-journal-plus me-2 text-primary"></i>Add Publication</h5>
                <form action="/admin/publications" method="POST">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Title <span class="text-danger">*</span></label>
                            <input class="form-control" name="title" placeholder="Publication title" required />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Category <span class="text-danger">*</span></label>
                            <input class="form-control" name="category" placeholder="e.g. Research" required />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Date Posted <span class="text-danger">*</span></label>
                            <input type="date" class="form-control" name="postedDate" required />
                        </div>
                        <div class="col-md-8">
                            <label class="form-label">Description <span class="text-danger">*</span></label>
                            <textarea class="form-control" name="description" rows="2" placeholder="Short description…" required></textarea>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Link (optional)</label>
                            <input class="form-control" name="buttonLink" placeholder="https://…" />
                        </div>
                        <div class="col-12">
                            <button class="btn btn-primary px-4"><i class="bi bi-plus-circle me-2"></i>Add Publication</button>
                        </div>
                    </div>
                </form>
            </div>

            <div class="table-card">
                <div class="p-3 border-bottom">
                    <span class="fw-600 text-secondary small text-uppercase">Publications (<%= publications.length %>)</span>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead><tr><th>Title</th><th>Category</th><th>Date</th><th>Link</th><th>Actions</th></tr></thead>
                        <tbody>
                        <% publications.forEach(p => { %>
                            <tr>
                                <td class="fw-semibold"><%= p.title %></td>
                                <td><span class="badge bg-primary bg-opacity-10 text-primary"><%= p.category %></span></td>
                                <td><small><%= new Date(p.postedDate).toLocaleDateString() %></small></td>
                                <td>
                                    <% if (p.buttonLink) { %>
                                        <a href="<%= p.buttonLink %>" target="_blank" class="btn btn-outline-secondary btn-sm">
                                            <i class="bi bi-link-45deg"></i> Open
                                        </a>
                                    <% } else { %><span class="text-muted small">—</span><% } %>
                                </td>
                                <td>
                                    <button class="btn btn-warning btn-sm me-1"
                                        onclick="editPublication('<%= p.id %>','<%- p.title.replace(/'/g, "\\'") %>','<%- (p.description || '').replace(/'/g, "\\'").replace(/\n/g, ' ') %>','<%- (p.category || '').replace(/'/g, "\\'") %>','<%- (p.buttonLink || '') %>','<%= p.postedDate ? new Date(p.postedDate).toISOString().split('T')[0] : '' %>')">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <form action="/admin/publications/delete/<%= p.id %>" method="POST" class="d-inline"
                                        onsubmit="return confirm('Delete this publication?')">
                                        <button type="submit" class="btn btn-danger btn-sm"><i class="bi bi-trash"></i></button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                        <% if (!publications.length) { %><tr><td colspan="5" class="text-center text-muted py-4">No publications yet.</td></tr><% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- ════════════════ PARTNERS ════════════════ -->
        <div class="admin-section" id="partners">
            <div class="section-hdr"><h4>Partners</h4></div>

            <div class="form-card">
                <h5><i class="bi bi-plus-circle me-2 text-primary"></i>Add Partner</h5>
                <form action="/admin/partners" method="POST">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Organisation Name <span class="text-danger">*</span></label>
                            <input class="form-control" name="name" placeholder="Partner name" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Website</label>
                            <input class="form-control" name="website" placeholder="https://…" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Logo URL</label>
                            <input class="form-control" name="logo" placeholder="https://…/logo.png" />
                        </div>
                        <div class="col-12">
                            <button class="btn btn-primary px-4"><i class="bi bi-plus-circle me-2"></i>Add Partner</button>
                        </div>
                    </div>
                </form>
            </div>

            <div class="table-card">
                <div class="p-3 border-bottom">
                    <span class="fw-600 text-secondary small text-uppercase">Partners (<%= partners.length %>)</span>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead><tr><th>Logo</th><th>Name</th><th>Website</th><th>Actions</th></tr></thead>
                        <tbody>
                        <% partners.forEach(p => { %>
                            <tr>
                                <td>
                                    <% if (p.logo) { %>
                                        <img src="<%= p.logo %>" alt="" style="height:36px;object-fit:contain;" onerror="this.style.display='none'" />
                                    <% } else { %><span class="text-muted small">—</span><% } %>
                                </td>
                                <td class="fw-semibold"><%= p.name %></td>
                                <td>
                                    <% if (p.website) { %>
                                        <a href="<%= p.website %>" target="_blank" class="text-decoration-none small"><%= p.website %></a>
                                    <% } else { %><span class="text-muted small">—</span><% } %>
                                </td>
                                <td>
                                    <form action="/admin/partners/delete/<%= p.id %>" method="POST" class="d-inline"
                                        onsubmit="return confirm('Delete this partner?')">
                                        <button type="submit" class="btn btn-danger btn-sm"><i class="bi bi-trash"></i></button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                        <% if (!partners.length) { %><tr><td colspan="4" class="text-center text-muted py-4">No partners yet.</td></tr><% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- ════════════════ JOBS ════════════════ -->
        <div class="admin-section" id="jobs">
            <div class="section-hdr"><h4>Jobs</h4></div>

            <div class="form-card">
                <h5><i class="bi bi-briefcase me-2 text-primary"></i>Post a Job</h5>
                <form action="/admin/jobs" method="POST">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Job Title <span class="text-danger">*</span></label>
                            <input class="form-control" name="title" placeholder="e.g. Field Officer" required />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Category <span class="text-danger">*</span></label>
                            <input class="form-control" name="category" placeholder="e.g. Full-time" required />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Deadline</label>
                            <input type="date" class="form-control" name="deadline" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Posted Date <span class="text-danger">*</span></label>
                            <input type="date" class="form-control" name="postedDate" required />
                        </div>
                        <div class="col-md-9">
                            <label class="form-label">Description <span class="text-danger">*</span></label>
                            <textarea class="form-control" name="description" rows="2" placeholder="Job description…" required></textarea>
                        </div>
                        <div class="col-12">
                            <button class="btn btn-primary px-4"><i class="bi bi-plus-circle me-2"></i>Post Job</button>
                        </div>
                    </div>
                </form>
            </div>

            <div class="table-card">
                <div class="p-3 border-bottom">
                    <span class="fw-600 text-secondary small text-uppercase">Posted Jobs (<%= jobs.length %>)</span>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead><tr><th>Title</th><th>Category</th><th>Posted</th><th>Deadline</th><th>Actions</th></tr></thead>
                        <tbody>
                        <% jobs.forEach(j => { %>
                            <tr>
                                <td class="fw-semibold"><%= j.title %></td>
                                <td><span class="badge bg-success bg-opacity-10 text-success"><%= j.category %></span></td>
                                <td><small><%= new Date(j.postedDate).toLocaleDateString() %></small></td>
                                <td><small><%= j.deadline ? new Date(j.deadline).toLocaleDateString() : '—' %></small></td>
                                <td>
                                    <form action="/admin/jobs/delete/<%= j.id %>" method="POST" class="d-inline"
                                        onsubmit="return confirm('Delete this job?')">
                                        <button type="submit" class="btn btn-danger btn-sm"><i class="bi bi-trash"></i></button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                        <% if (!jobs.length) { %><tr><td colspan="5" class="text-center text-muted py-4">No jobs posted.</td></tr><% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- ════════════════ JOB APPLICATIONS ════════════════ -->
        <div class="admin-section" id="applications">
            <div class="section-hdr"><h4>Job Applications</h4></div>
            <div class="table-card">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead><tr><th>Name</th><th>Email</th><th>Job</th><th>Cover Letter</th><th>CV</th><th>Applied</th></tr></thead>
                        <tbody>
                        <% applications.forEach(a => { %>
                            <tr>
                                <td class="fw-semibold"><%= a.name %></td>
                                <td><a href="mailto:<%= a.email %>"><%= a.email %></a></td>
                                <td><small><%= a.job ? a.job.title : '—' %></small></td>
                                <td><small class="text-muted"><%= (a.coverLetter || '—').substring(0,60) %>…</small></td>
                                <td>
                                    <% if (a.cv) { %>
                                        <a href="/uploads/<%= a.cv %>" target="_blank" class="btn btn-outline-secondary btn-sm">
                                            <i class="bi bi-file-earmark-person"></i> CV
                                        </a>
                                    <% } else { %><span class="text-muted small">—</span><% } %>
                                </td>
                                <td><small><%= a.appliedAt ? new Date(a.appliedAt).toLocaleDateString() : '—' %></small></td>
                            </tr>
                        <% }) %>
                        <% if (!applications.length) { %><tr><td colspan="6" class="text-center text-muted py-4">No applications yet.</td></tr><% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>


        <!-- ════════════════ MEMBERSHIPS ════════════════ -->
        <div class="admin-section" id="memberships">
            <div class="section-hdr"><h4>Membership Requests</h4></div>
            <div class="table-card">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead><tr><th>Name</th><th>Email</th><th>Phone</th><th>Organisation</th><th>Plan</th><th>Submitted</th></tr></thead>
                        <tbody>
                        <% membershipRequests.forEach(m => { %>
                            <tr>
                                <td class="fw-semibold"><%= m.name %></td>
                                <td><a href="mailto:<%= m.email %>"><%= m.email %></a></td>
                                <td><%= m.phone %></td>
                                <td><%= m.organization || '—' %></td>
                                <td><span class="badge bg-info bg-opacity-10 text-info text-capitalize"><%= m.plan %></span></td>
                                <td><small><%= new Date(m.submittedAt).toLocaleDateString() %></small></td>
                            </tr>
                        <% }) %>
                        <% if (!membershipRequests.length) { %><tr><td colspan="6" class="text-center text-muted py-4">No membership requests.</td></tr><% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- ════════════════ NEWSLETTER ════════════════ -->
        <div class="admin-section" id="newsletter">
            <div class="section-hdr">
                <h4>Newsletter Subscribers</h4>
                <span class="badge bg-primary fs-6"><%= newsletterSubscribers.length %> subscribers</span>
            </div>
            <div class="table-card">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead><tr><th>Email</th><th>Subscribed</th><th>Action</th></tr></thead>
                        <tbody>
                        <% newsletterSubscribers.forEach(n => { %>
                            <tr>
                                <td><%= n.email %></td>
                                <td><small><%= new Date(n.submittedAt).toLocaleDateString() %></small></td>
                                <td>
                                    <a href="mailto:<%= n.email %>" class="btn btn-outline-primary btn-sm">
                                        <i class="bi bi-envelope"></i> Email
                                    </a>
                                </td>
                            </tr>
                        <% }) %>
                        <% if (!newsletterSubscribers.length) { %><tr><td colspan="3" class="text-center text-muted py-4">No subscribers yet.</td></tr><% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- ════════════════ CONTACTS ════════════════ -->
        <div class="admin-section" id="contacts">
            <div class="section-hdr"><h4>Contact Inquiries</h4></div>
            <div class="table-card">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead><tr><th>Name</th><th>Email</th><th>Phone</th><th>Message</th></tr></thead>
                        <tbody>
                        <% contacts.forEach(c => { %>
                            <tr>
                                <td class="fw-semibold"><%= c.fullName %></td>
                                <td><a href="mailto:<%= c.email %>"><%= c.email %></a></td>
                                <td><%= c.phone || '—' %></td>
                                <td><small class="text-muted"><%= (c.message || '').substring(0,80) %><%= (c.message || '').length > 80 ? '…' : '' %></small></td>
                            </tr>
                        <% }) %>
                        <% if (!contacts.length) { %><tr><td colspan="4" class="text-center text-muted py-4">No inquiries yet.</td></tr><% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div><!-- /content -->
</div><!-- /main -->


<!-- ════════════ MODALS ════════════ -->

<!-- Edit Annual Report Modal -->
<div class="modal fade" id="editReportModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <form id="editReportForm" method="POST" enctype="multipart/form-data" class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-pencil me-2"></i>Edit Report</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="editReportId" name="id">
                <div class="mb-3">
                    <label class="form-label">Title</label>
                    <input type="text" class="form-control" name="reportTitle" id="editReportTitle" required>
                </div>
                <div class="mb-3">
                    <label class="form-label">Year</label>
                    <input type="number" class="form-control" name="reportYear" id="editReportYear" required>
                </div>
                <div class="mb-3">
                    <label class="form-label">Description</label>
                    <textarea class="form-control" name="description" id="editReportDescription" rows="3"></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label">Replace File <small class="text-muted">(optional)</small></label>
                    <input type="file" class="form-control" name="reportFile" accept=".pdf,.doc,.docx">
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-success"><i class="bi bi-floppy me-1"></i>Save Changes</button>
            </div>
        </form>
    </div>
</div>

<!-- Edit Team Member Modal -->
<div class="modal fade" id="editTeamModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <form id="editTeamForm" method="POST" enctype="multipart/form-data" class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-pencil me-2"></i>Edit Team Member</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" name="id" id="editTeamId">
                <div class="mb-3">
                    <label class="form-label">Full Name</label>
                    <input type="text" class="form-control" name="fullName" id="editTeamName" required>
                </div>
                <div class="mb-3">
                    <label class="form-label">Role</label>
                    <input type="text" class="form-control" name="role" id="editTeamRole" required>
                </div>
                <div class="mb-3">
                    <label class="form-label">Bio / Description</label>
                    <textarea class="form-control" name="description" id="editTeamDescription" rows="3"></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label">Change Photo <small class="text-muted">(optional)</small></label>
                    <input type="file" class="form-control" name="image" accept="image/*">
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-success"><i class="bi bi-floppy me-1"></i>Save Changes</button>
            </div>
        </form>
    </div>
</div>

<!-- Edit Publication Modal -->
<div class="modal fade" id="editPublicationModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <form id="editPublicationForm" method="POST" class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-pencil me-2"></i>Edit Publication</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="editPubId" name="id">
                <div class="mb-3">
                    <label class="form-label">Title</label>
                    <input type="text" class="form-control" name="title" id="editPubTitle" required>
                </div>
                <div class="mb-3">
                    <label class="form-label">Description</label>
                    <textarea class="form-control" name="description" id="editPubDescription" rows="3" required></textarea>
                </div>
                <div class="row g-2 mb-3">
                    <div class="col">
                        <label class="form-label">Category</label>
                        <input type="text" class="form-control" name="category" id="editPubCategory" required>
                    </div>
                    <div class="col">
                        <label class="form-label">Date</label>
                        <input type="date" class="form-control" name="postedDate" id="editPubPostedDate" required>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Link (optional)</label>
                    <input type="text" class="form-control" name="buttonLink" id="editPubButtonLink">
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-success"><i class="bi bi-floppy me-1"></i>Save Changes</button>
            </div>
        </form>
    </div>
</div>


<!-- ════════════ SCRIPTS ════════════ -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
    // ── Section navigation ─────────────────────────────────────────
    function showSection(id, btn) {
        document.querySelectorAll('.admin-section').forEach(s => s.classList.remove('active'));
        document.querySelectorAll('.s-link').forEach(l => l.classList.remove('active'));
        document.getElementById(id).classList.add('active');
        if (btn) btn.classList.add('active');
        const titles = {
            'dashboard':'Dashboard','annual-reports':'Annual Reports','team':'Team Members',
            'publications':'Publications','partners':'Partners','jobs':'Jobs',
            'applications':'Job Applications',
            'memberships':'Membership Requests','newsletter':'Newsletter Subscribers',
            'contacts':'Contact Inquiries'
        };
        document.getElementById('topbarTitle').textContent = titles[id] || id;
        window.location.hash = id;
        if (window.innerWidth <= 768) closeSidebar();
    }

    // Restore section from URL hash on load
    window.addEventListener('DOMContentLoaded', () => {
        const hash = window.location.hash.slice(1);
        const btn = document.querySelector(`[data-section="${hash}"]`);
        if (hash && document.getElementById(hash) && btn) showSection(hash, btn);
    });

    // ── Mobile sidebar ─────────────────────────────────────────────
    function openSidebar() {
        document.getElementById('sidebar').classList.add('open');
        document.getElementById('overlay').classList.add('show');
    }
    function closeSidebar() {
        document.getElementById('sidebar').classList.remove('open');
        document.getElementById('overlay').classList.remove('show');
    }

    // ── Edit Report ────────────────────────────────────────────────
    function editReport(id, title, year, description) {
        document.getElementById('editReportId').value   = id;
        document.getElementById('editReportTitle').value = title;
        document.getElementById('editReportYear').value  = year;
        document.getElementById('editReportDescription').value = description;
        document.getElementById('editReportForm').action = `/admin/annual-reports/edit/${id}`;
        new bootstrap.Modal(document.getElementById('editReportModal')).show();
    }

    // ── Edit Team Member ───────────────────────────────────────────
    function editMember(btn) {
        document.getElementById('editTeamId').value          = btn.dataset.id;
        document.getElementById('editTeamName').value        = btn.dataset.name;
        document.getElementById('editTeamRole').value        = btn.dataset.role;
        document.getElementById('editTeamDescription').value = btn.dataset.description;
        document.getElementById('editTeamForm').action = `/admin/team/edit/${btn.dataset.id}`;
        new bootstrap.Modal(document.getElementById('editTeamModal')).show();
    }

    // ── Edit Publication ───────────────────────────────────────────
    function editPublication(id, title, description, category, buttonLink, postedDate) {
        document.getElementById('editPubId').value          = id;
        document.getElementById('editPubTitle').value       = title;
        document.getElementById('editPubDescription').value = description;
        document.getElementById('editPubCategory').value    = category;
        document.getElementById('editPubButtonLink').value  = buttonLink || '';
        document.getElementById('editPubPostedDate').value  = postedDate;
        document.getElementById('editPublicationForm').action = `/admin/publications/edit/${id}`;
        new bootstrap.Modal(document.getElementById('editPublicationModal')).show();
    }
</script>
</body>
</html>
